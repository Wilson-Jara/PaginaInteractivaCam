---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import GameCard from "../components/GameCard.astro";
import { games } from "../data/games";
---

<Layout title="GameHub - Juegos Interactivos">
  <Navbar />

  <main class="main-content">
    <div class="content-container">
      <div class="page-header">
        <h1 class="page-title">Juegos</h1>
        <p class="page-description">
          Juegos interactivos controlados con la cámara y tus manos mediante
          MediaPipe. Elige uno y empieza a jugar.
        </p>
      </div>

      <div class="games-grid">
        {games.map((game) => (
          <GameCard
            id={game.id}
            title={game.title}
            cover={game.cover}
            tags={game.tags}
            size={game.size}
            category={game.category}
            description={game.description}
            playable={game.playable}
          />
        ))}
      </div>
    </div>
  </main>

  <Footer />
</Layout>

<style>
  .main-content {
    min-height: calc(100vh - 56px);
  }

  .content-container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 2.5rem 1.5rem;
  }

  .page-header {
    margin-bottom: 2.2rem;
  }

  .page-title {
    font-size: 2.6rem;
    font-weight: 800;
    letter-spacing: -0.5px;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
  }

  .page-description {
    font-size: 1rem;
    color: var(--text-secondary);
    max-width: 760px;
    line-height: 1.6;
  }

  /* Grilla de 3 columnas con tarjetas grandes, como Aimlabs. */
  .games-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.6rem;
  }

  @media (max-width: 1000px) {
    .games-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .games-grid {
      grid-template-columns: 1fr;
    }

    .page-title {
      font-size: 2rem;
    }

    .content-container {
      padding: 1.5rem 1rem;
    }
  }
</style>
