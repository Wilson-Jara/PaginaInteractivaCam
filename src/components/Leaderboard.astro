---
// ============================================================
//  TABLA DE LIDERES (Leaderboard) — Top 10
// ============================================================
//  Muestra el Top 10 de un juego en TIEMPO REAL desde Firestore.
//  - Todos pueden VER la tabla.
//  - Solo el ADMIN logueado puede GUARDAR un nombre cuando se
//    logra un récord del Top 10 (la seguridad real la imponen
//    las reglas de Firestore, no este componente).
//
//  Props:
//   - gameId: id del juego (coincide con games.ts). Default "block-breaker".
//   - interactive: si es false, solo muestra la tabla (sin login
//     ni guardado). Útil en la página de detalle del juego.
//   - title: encabezado del panel.
// ============================================================
interface Props {
  gameId?: string;
  interactive?: boolean;
  title?: string;
}
const {
  gameId = "block-breaker",
  interactive = true,
  title = "🏆 Top 15",
} = Astro.props;
---

<section
  class="leaderboard"
  data-leaderboard
  data-game-id={gameId}
  data-interactive={interactive ? "1" : "0"}
>
  <h3 class="lb-title">{title}</h3>

  <div class="lb-head">
    <span class="lb-head-rank"></span>
    <span class="lb-head-name">Nombre</span>
    <span class="lb-head-score">Score</span>
  </div>

  <ol class="lb-list" data-lb-list>
    <li class="lb-loading">Cargando…</li>
  </ol>

  {interactive && (
    <div class="lb-bottom" data-lb-bottom hidden>
      {/* Aviso de récord (visible al terminar la partida) */}
      <div class="lb-record" data-lb-record hidden>
        <p class="lb-record-text" data-lb-record-text></p>

        {/* Formulario de guardado: SOLO visible para el admin logueado */}
        <form class="lb-save" data-lb-save hidden>
          <input
            class="lb-input"
            data-lb-name
            type="text"
            maxlength="20"
            placeholder="Nombre del jugador"
            autocomplete="off"
            required
          />
          <button class="lb-btn" type="submit">Guardar récord</button>
        </form>

        <p class="lb-msg" data-lb-msg hidden></p>
      </div>
    </div>
  )}
</section>

<script>
  import { db, auth, isFirebaseConfigured } from "../lib/firebase";
  import {
    collection,
    query,
    orderBy,
    limit,
    onSnapshot,
    addDoc,
    serverTimestamp,
  } from "firebase/firestore";
  import { onAuthStateChanged } from "firebase/auth";

  type ScoreRow = { name: string; score: number };

  function initPanel(root: HTMLElement) {
    const gameId = root.dataset.gameId || "block-breaker";
    const interactive = root.dataset.interactive === "1";

    const listEl = root.querySelector<HTMLElement>("[data-lb-list]")!;

    // --- Render de la tabla ---
    let scores: ScoreRow[] = [];
    function renderList() {
      if (scores.length === 0) {
        listEl.innerHTML = `<li class="lb-empty">Sin récords todavía</li>`;
        return;
      }
      listEl.innerHTML = scores
        .map((s, i) => {
          const medal = i === 0 ? "🥇" : i === 1 ? "🥈" : i === 2 ? "🥉" : `${i + 1}.`;
          const name = escapeHtml(s.name);
          // Puntaje con separador de miles (1.870), sin relleno de ceros.
          const pts = s.score.toLocaleString("es-ES");
          return `<li class="lb-row"><span class="lb-rank">${medal}</span><span class="lb-name">${name}</span><span class="lb-score">${pts}</span></li>`;
        })
        .join("");
    }

    // Si Firebase aún no está configurado, no intentamos conectar.
    if (!isFirebaseConfigured) {
      listEl.innerHTML = `<li class="lb-empty">Configura Firebase para ver la tabla</li>`;
      return;
    }

    const scoresRef = collection(db, "games", gameId, "scores");
    const topQuery = query(scoresRef, orderBy("score", "desc"), limit(15));

    onSnapshot(
      topQuery,
      (snap) => {
        scores = snap.docs.map((d) => {
          const data = d.data() as any;
          return { name: String(data.name ?? "—"), score: Number(data.score ?? 0) };
        });
        renderList();
      },
      (err) => {
        console.warn("Leaderboard onSnapshot:", err);
        listEl.innerHTML = `<li class="lb-empty">No se pudo cargar la tabla</li>`;
      }
    );

    if (!interactive) return;

    // ---------- Modo interactivo (juego): guardar récord ----------
    // El login es global (componente AdminLogin en la barra). Aquí solo
    // reaccionamos a la sesión y mostramos el formulario de guardado.
    const bottomBox = root.querySelector<HTMLElement>("[data-lb-bottom]")!;
    const recordBox = root.querySelector<HTMLElement>("[data-lb-record]")!;
    const recordText = root.querySelector<HTMLElement>("[data-lb-record-text]")!;
    const saveForm = root.querySelector<HTMLFormElement>("[data-lb-save]")!;
    const nameInput = root.querySelector<HTMLInputElement>("[data-lb-name]")!;
    const msgEl = root.querySelector<HTMLElement>("[data-lb-msg]")!;

    let isAdmin = false;
    let pendingScore: number | null = null;

    function showMsg(text: string) {
      msgEl.textContent = text;
      msgEl.hidden = !text;
    }

    function qualifies(score: number) {
      if (score <= 0) return false;
      if (scores.length < 15) return true;
      return score > scores[scores.length - 1].score;
    }

    function refreshRecordUI() {
      const show = pendingScore !== null && qualifies(pendingScore);
      bottomBox.hidden = !show;
      recordBox.hidden = !show;
      if (show) {
        if (isAdmin) {
          recordText.textContent = `¡Top 15 con ${pendingScore} puntos! Escribe el nombre:`;
          saveForm.hidden = false;
        } else {
          recordText.textContent = `¡Top 15 con ${pendingScore} puntos! Inicia sesión como admin para guardarlo.`;
          saveForm.hidden = true;
        }
      } else {
        saveForm.hidden = true;
      }
    }

    // --- Eventos del juego (contrato genérico engine/events.ts) ---
    window.addEventListener("game:over", (e: Event) => {
      const detail = (e as CustomEvent).detail || {};
      if (detail.gameId && detail.gameId !== gameId) return;
      pendingScore = Number(detail.score ?? 0);
      refreshRecordUI();
    });
    window.addEventListener("game:restart", (e: Event) => {
      const detail = (e as CustomEvent).detail || {};
      if (detail.gameId && detail.gameId !== gameId) return;
      pendingScore = null;
      refreshRecordUI();
    });

    // --- Sesión admin global ---
    onAuthStateChanged(auth, (user) => {
      isAdmin = !!user;
      showMsg("");
      refreshRecordUI();
    });

    // --- Guardar récord ---
    saveForm.addEventListener("submit", async (e) => {
      e.preventDefault();
      if (!isAdmin || pendingScore === null) return;
      const name = nameInput.value.trim().slice(0, 20);
      if (!name) return;
      showMsg("Guardando…");
      try {
        await addDoc(collection(db, "games", gameId, "scores"), {
          name,
          score: Math.round(pendingScore),
          createdAt: serverTimestamp(),
        });
        nameInput.value = "";
        pendingScore = null;
        refreshRecordUI();
        showMsg("¡Récord guardado!");
        setTimeout(() => showMsg(""), 2500);
      } catch (err: any) {
        showMsg("No se pudo guardar (¿permisos de admin?).");
        console.warn("save score:", err?.code || err);
      }
    });
  }

  function escapeHtml(s: string) {
    return s
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;");
  }

  document
    .querySelectorAll<HTMLElement>("[data-leaderboard]")
    .forEach((el) => initPanel(el));
</script>

<style>
  .leaderboard {
    width: 280px;
    max-width: 100%;
    height: 100%;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1rem 1.1rem;
    color: var(--text-primary);
    font-family: "Inter", sans-serif;
    display: flex;
    flex-direction: column;
  }

  .lb-title {
    font-size: 1.5rem;
    font-weight: 800;
    margin-bottom: 1rem;
    text-align: center;
    color: var(--text-primary);
    flex: 0 0 auto;
  }

  /* Encabezados de columna alineados con las filas.
     Grid de 3 columnas proporcionales: rango | nombre | score. El score arranca
     a la mitad del panel (no pegado al borde derecho), sin importar el ancho. */
  .lb-head {
    display: grid;
    grid-template-columns: 2.6rem 2.5fr 1fr;
    align-items: center;
    gap: 0.9rem;
    width: 100%;
    box-sizing: border-box;
    flex: 0 0 auto;
    padding: 0 1.1rem 0.55rem;
    margin-bottom: 0.5rem;
    border-bottom: 1px solid var(--border);
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--text-secondary);
  }
  .lb-head-score { text-align: left; }

  .lb-list {
    list-style: none;
    width: 100%;
    flex: 1 1 auto;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    gap: 6px;
    min-height: 0;
  }

  /* Cada fila: rango | nombre (izquierda) | puntaje (columna fija a la derecha).
     width:100% garantiza que el puntaje se vaya a la orilla, no pegado al nombre.
     flex reparte la altura para llenar el panel con 15 nombres.
     OJO: las filas las crea el JS (innerHTML), así que sus selectores deben ser
     :global — los estilos scoped de Astro NO aplican a elementos creados en runtime. */
  .lb-list :global(.lb-row) {
    display: grid;
    grid-template-columns: 2.6rem 2.5fr 1fr;
    align-items: center;
    gap: 0.9rem;
    width: 100%;
    box-sizing: border-box;
    flex: 1 1 0;
    min-height: 42px;
    max-height: 60px;
    padding: 0 1.1rem;
    border-radius: 7px;
    font-size: 1.2rem;
    background: var(--bg-primary);
  }

  .lb-list :global(.lb-row:nth-child(odd)) {
    background: rgba(0, 0, 0, 0.18);
  }

  .lb-list :global(.lb-rank) {
    text-align: center;
    color: var(--text-secondary);
    font-weight: 700;
    font-size: 1.15rem;
  }

  .lb-list :global(.lb-name) {
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    font-weight: 600;
  }

  .lb-list :global(.lb-score) {
    text-align: left;
    font-variant-numeric: tabular-nums;
    color: var(--accent);
    font-weight: 800;
    font-size: 1.15rem;
    letter-spacing: 0.5px;
  }

  .lb-list :global(.lb-loading),
  .lb-list :global(.lb-empty) {
    list-style: none;
    text-align: center;
    color: var(--text-muted);
    font-size: 0.9rem;
    padding: 1rem 0;
    flex: 1 1 auto;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .lb-bottom {
    margin-top: 0.85rem;
    border-top: 1px solid var(--border);
    padding-top: 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    flex: 0 0 auto;
  }

  .lb-record {
    background: rgba(102, 192, 244, 0.1);
    border: 1px solid var(--accent);
    border-radius: 6px;
    padding: 0.6rem;
  }

  .lb-record-text {
    font-size: 0.8rem;
    margin-bottom: 0.5rem;
    line-height: 1.4;
  }

  .lb-save {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .lb-input {
    width: 100%;
    padding: 0.45rem 0.55rem;
    font-size: 0.82rem;
    background: var(--bg-primary);
    color: var(--text-primary);
    border: 1px solid var(--border);
    border-radius: 4px;
    font-family: inherit;
  }

  .lb-input:focus {
    outline: none;
    border-color: var(--accent);
  }

  .lb-btn {
    padding: 0.45rem 0.6rem;
    font-size: 0.82rem;
    font-weight: 600;
    color: #fff;
    background: var(--accent);
    border: none;
    border-radius: 4px;
    cursor: pointer;
    transition: background 0.2s;
  }

  .lb-btn:hover {
    background: var(--accent-hover);
  }

  .lb-msg {
    font-size: 0.75rem;
    color: var(--accent-orange);
  }
</style>
