---
import AdminLogin from "./AdminLogin.astro";
---

<nav class="navbar">
  <div class="navbar-container">
    <a href="/" class="navbar-logo">
      <span class="logo-text">JUEGOS</span>
    </a>
    <AdminLogin />
  </div>
</nav>

<style>
  .navbar {
    background: var(--bg-navbar);
    border-bottom: 1px solid var(--border);
  }

  .navbar-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 56px;
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .navbar-logo {
    display: flex;
    align-items: center;
    font-size: 1.2rem;
    font-weight: 700;
    flex-shrink: 0;
    margin-right: 1rem;
  }
</style>
