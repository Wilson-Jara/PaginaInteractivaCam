---
// ============================================================
//  GAME SHELL — contenedor reutilizable para cualquier CameraGame
// ============================================================
//  Monta el layout común (lienzo + leaderboard + panel de cámara +
//  espacio para imagen) y arranca el motor cargando el juego por
//  su `gameId` desde el registry. Sirve para TODOS los juegos.
//
//  Props:
//   - gameId: id del juego (debe existir en gameRegistry y games.ts).
// ============================================================
import Leaderboard from "./Leaderboard.astro";

interface Props {
  gameId: string;
}
const { gameId } = Astro.props;
---

<div id="game-wrapper" data-game-shell data-game-id={gameId}>
  <aside id="leaderboard-side">
    <Leaderboard gameId={gameId} interactive={true} />
  </aside>

  <div id="game-container">
    <canvas id="gameCanvas"></canvas>
    <div id="loading">Iniciando...</div>
  </div>

  <div id="right-col">
    <div id="cam-box">
      <video id="camVideo" autoplay playsinline muted></video>
      <canvas id="camOverlay"></canvas>
      <span id="cam-label">📷 Cámara</span>
    </div>
    <div id="img-box">
      <img id="user-img" alt="Imagen personalizada" hidden />
      <span class="img-placeholder">Espacio para imagen</span>
      <input id="img-file" type="file" accept="image/*" hidden />
      <button id="img-btn" type="button">📁 Seleccionar imagen</button>
    </div>
  </div>
</div>

<script>
  import { getGameFactory } from "../lib/gameRegistry";
  import { HandTracker } from "../engine/HandTracker";
  import { GameRuntime } from "../engine/GameRuntime";

  const shell = document.querySelector<HTMLElement>("[data-game-shell]");
  const canvas = document.getElementById("gameCanvas") as HTMLCanvasElement | null;
  const video = document.getElementById("camVideo") as HTMLVideoElement | null;
  const overlay = document.getElementById("camOverlay") as HTMLCanvasElement | null;
  const camLabel = document.getElementById("cam-label");
  const loadingEl = document.getElementById("loading");

  function setLoading(message: string, hideAfterMs?: number) {
    if (!loadingEl) return;
    loadingEl.textContent = message;
    loadingEl.style.display = "block";
    if (hideAfterMs) setTimeout(() => (loadingEl.style.display = "none"), hideAfterMs);
  }

  async function boot() {
    if (!shell || !canvas || !video) return;
    const gameId = shell.dataset.gameId || "";
    const factory = getGameFactory(gameId);
    if (!factory) {
      setLoading("Este juego aún no está disponible.");
      return;
    }

    const game = await factory();
    // En móvil la inferencia es más lenta (más latencia): predecimos más.
    const isMobile = /Android|iPhone|iPad|iPod|Mobile|Opera Mini|IEMobile/i.test(
      navigator.userAgent
    );
    const tracker = new HandTracker({
      video,
      overlay,
      onStatus: (msg, hide) => setLoading(msg, hide),
      // Predicción de latencia: adelanta el retraso del pipeline de cámara.
      predictMs: isMobile ? 150 : 90,
    });
    const runtime = new GameRuntime({
      game,
      canvas,
      tracker,
      verticalMargin: 68,
      // Ancho real reservado por leaderboard(380) + cámara/imagen(560) +
      // gaps(32) + padding(48), menos el margin(24) que ya resta el motor.
      sidePanelWidth: 996,
    });

    // Arrancamos el loop primero: el juego es jugable con mouse/teclado
    // aunque la cámara/MediaPipe tarden o fallen.
    runtime.start();

    setLoading("Solicitando camara...");
    const res = await tracker.start();
    if (!res.camera) {
      video.style.display = "none";
      if (camLabel) camLabel.textContent = "Sin cámara";
    }
  }

  // --- Selector de imagen del cuadro derecho ---
  // Permite elegir un archivo del PC; se muestra en el cuadro y se recuerda
  // en localStorage (por juego) para que siga ahí al recargar.
  function setupImagePicker() {
    const imgBox = document.getElementById("img-box");
    const imgEl = document.getElementById("user-img") as HTMLImageElement | null;
    const fileInput = document.getElementById("img-file") as HTMLInputElement | null;
    const imgBtn = document.getElementById("img-btn");
    const placeholder = imgBox?.querySelector<HTMLElement>(".img-placeholder");
    if (!imgBox || !imgEl || !fileInput || !imgBtn) return;

    const key = "gamehub:userImage:" + (shell?.dataset.gameId || "default");

    function applyImage(dataUrl: string) {
      imgEl!.src = dataUrl;
      imgEl!.hidden = false;
      if (placeholder) placeholder.style.display = "none";
    }

    const saved = localStorage.getItem(key);
    if (saved) applyImage(saved);

    imgBtn.addEventListener("click", () => fileInput.click());
    fileInput.addEventListener("change", () => {
      const file = fileInput.files?.[0];
      if (!file) return;
      const reader = new FileReader();
      reader.onload = () => {
        const url = String(reader.result);
        applyImage(url);
        try {
          localStorage.setItem(key, url);
        } catch {
          // La imagen es muy grande para localStorage: se ve esta sesión igual.
        }
      };
      reader.readAsDataURL(file);
    });
  }

  setupImagePicker();
  boot();
</script>

<style is:global>
  @import url("https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap");
  /* En la página de juego no queremos NINGÚN scroll: el lienzo ya se
     escala para caber en la ventana. */
  html, body { overflow: hidden; }
  #game-wrapper * { margin: 0; padding: 0; box-sizing: border-box; }
  #game-wrapper {
    width: 100%; height: calc(100vh - 56px);
    display: flex; align-items: stretch; justify-content: space-between;
    gap: 16px; padding: 6px 24px; background: var(--bg-primary); overflow: hidden;
  }
  /* Columna izquierda: leaderboard en la orilla izquierda, a toda la altura.
     Crece (flex-grow) para absorber el espacio que deja el lienzo del juego. */
  #leaderboard-side { flex: 1 1 380px; display: flex; }
  #leaderboard-side .leaderboard { width: 100%; }
  /* Centro: el contenedor se ciñe al lienzo (no deja huecos laterales). */
  #game-container {
    position: relative; flex: 0 0 auto;
    display: flex; align-items: flex-start; justify-content: center;
  }
  /* Columna derecha: cámara arriba + imagen ocupando el resto. */
  #right-col {
    flex: 0 0 560px;
    display: flex; flex-direction: column; gap: 6px;
  }
  #gameCanvas { display: block; border-radius: 4px; }
  #loading { position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%); color: #aaa; font: 16px 'Press Start 2P', monospace; text-align: center; line-height: 1.5; }

  #cam-box {
    position: relative; width: 100%; flex: 1 1 0; min-height: 0;
    background: var(--bg-card); border: 1px solid var(--border); border-radius: 6px;
    overflow: hidden;
  }
  #camVideo, #camOverlay {
    position: absolute; inset: 0; width: 100%; height: 100%;
    object-fit: cover; transform: scaleX(-1); /* efecto espejo */
  }
  #cam-label {
    position: absolute; top: 6px; left: 8px; z-index: 2;
    font: 10px 'Press Start 2P', monospace; color: var(--text-primary);
    background: rgba(0,0,0,0.45); padding: 3px 6px; border-radius: 4px;
  }

  #img-box {
    position: relative;
    width: 100%; flex: 1 1 0; min-height: 0;
    background: var(--bg-card); border: 1px dashed var(--border); border-radius: 6px;
    display: flex; align-items: center; justify-content: center;
    overflow: hidden;
  }
  #img-box img { width: 100%; height: 100%; object-fit: contain; }
  .img-placeholder { color: var(--text-muted); font: 12px 'Press Start 2P', monospace; text-align: center; padding: 1rem; }
  #img-btn {
    position: absolute; bottom: 10px; left: 50%; transform: translateX(-50%);
    z-index: 2; padding: 8px 14px; border-radius: 6px; cursor: pointer;
    border: 1px solid var(--border); background: rgba(0,0,0,0.6); color: var(--text-primary);
    font: 11px 'Press Start 2P', monospace; transition: background 0.2s;
  }
  #img-btn:hover { background: var(--accent); color: #fff; }

  @media (max-width: 1100px) {
    html, body { overflow: auto; }
    #game-wrapper {
      flex-direction: column; align-items: center; justify-content: flex-start;
      height: auto; min-height: calc(100vh - 56px); overflow: visible;
    }
    #leaderboard-side, #right-col {
      flex: none; width: 100%; max-width: 480px;
    }
    #game-container { margin-right: 0; }
    #right-col { flex-direction: row; }
    #cam-box, #img-box { flex: 1; aspect-ratio: 4 / 3; }
  }
</style>
